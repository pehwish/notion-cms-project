# Notion API 인증 정보
# Notion 통합을 생성하여 얻은 API 키를 입력하세요
# 참고: https://developers.notion.com
NOTION_API_KEY=your_notion_api_key_here

# Notion Blog Posts 데이터베이스 ID
# Notion에서 Blog Posts 데이터베이스를 생성 후, URL에서 ID를 추출하세요
# 예: https://notion.so/your-workspace/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=your_database_id_here
